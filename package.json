{
  "name": "medical-twins",
  "description": "Clinical AI Studio: A React-based Agent-Based Modeling system combining WebAssembly Edge Inference and Generative AI for digital patient cohort tracking.",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "electron:start": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "electron:serve": "concurrently -k \"npm run dev\" \"wait-on http://localhost:5173 && npm run electron:start\"",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.clinical.medicaltwins",
    "productName": "Medical Twins Studio",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": ["nsis"]
    },
    "mac": {
      "target": ["dmg"]
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ]
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@types/peerjs": "^0.0.30",
    "@types/three": "^0.183.1",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^0.577.0",
    "onnxruntime-web": "^1.24.3",
    "peerjs": "^1.5.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-force-graph-2d": "^1.29.1",
    "react-hot-toast": "^2.6.0",
    "react-is": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "three": "^0.183.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  }
}
